# Django runtime
DJANGO_SETTINGS_MODULE=fake_image_detector.cloud_settings
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your-domain.com,127.0.0.1

# Database (MySQL/MariaDB recommended)
DB_ENGINE=django.db.backends.mysql
DB_NAME=academic_plagiarism_detector
DB_USER=app_user
DB_PASSWORD=change_me
DB_HOST=127.0.0.1
DB_PORT=3306

# Redis / Celery / Channels
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# AI bridge
AI_SERVICE_URL=http://127.0.0.1:8010
AI_SERVICE_TIMEOUT_SECONDS=120

# CORS
CORS_ALLOW_ALL_ORIGINS=false

